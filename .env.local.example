# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored — never commit real secrets.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for the AI assistant and pgvector embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-your-openai-key

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=fifth-felony-dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3002
